def BQueue(n) returns q:
    q = { .max: n, .items: [] }

def bq_put(bq, v):
    atomically when len(bq->items) < bq->max:
        bq->items += [v,]

def bq_get(bq) returns v:
    atomically when len(bq->items) > 0:
        v = bq->items[0]
        del bq->items[0]

def bq_peek(bq) returns v:
    atomically when len(bq->items) > 0:
        v = bq->items[0]

def bq_clear(bq):
    atomically:
        bq->items = []

def BQueue(n) returns q:
    q = { .max: n, .items: [] }

def bq_put(q, v):
    atomically:
        while len(q->items) >= q->max:
            pass
        q->items += [v,]

def bq_get(q) returns v:
    atomically:
        while len(q->items) == 0:
            pass
        v = q->items[0]
        del q->items[0]

def bq_peek(q) returns v:
    atomically:
        while len(q->items) == 0:
            pass
        v = q->items[0]

def bq_clear(q):
    atomically:
        q->items = []
